{
  "buildCommand": "pnpm -w run vercel-build",
  "outputDirectory": "artifacts/dj-site/dist",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs18.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!assets|images|favicon.svg|opengraph.jpg).*)", "destination": "/index.html" }
  ]
}
